# Local SAM / AWS
.aws-sam/
samconfig.toml
packaged.yaml
.env

# Python
__pycache__/
*.py[cod]
.pytest_cache/
.venv/
venv/
.venv-pptx/
*.egg-info/
dist/
build/

# Node / frontend
node_modules/
frontend/dist/

# OS / IDE
.DS_Store
.idea/
.vscode/


# docs/ — Markdown, Mermaid & plain text (keep README*)
docs/**/*.md
docs/**/*.mmd
docs/**/*.txt
!docs/**/README.md
!docs/**/Readme.md
!docs/**/readme.md
!docs/**/README.txt
!docs/**/Readme.txt
!docs/**/readme.txt

# docs/ — Office lock files
docs/**/~$*

# docs/report — entire folder (all contents; overrides un-ignore rules above for this path)
docs/report/

# IoT device certs / keys (keep local only; never commit)
docs/**/*.pem
docs/**/*.pem.crt
docs/**/*.pem.key
