# Paste your REAL stack output (HttpApiUrl) — NOT the docs placeholder "abc123".
# After: cd backend && sam deploy
# Copy from CloudFormation Outputs or: aws cloudformation describe-stacks --stack-name YOUR_STACK --query "Stacks[0].Outputs[?OutputKey=='HttpApiUrl'].OutputValue" --output text
#
# No trailing slash. Example shape (your id and region will differ):
# VITE_API_BASE_URL=https://a1b2c3d4e5.execute-api.us-east-1.amazonaws.com

VITE_API_BASE_URL=

# Optional: how often the UI refetches GET routes (ms). Min 2000, default 4000.
# VITE_POLL_INTERVAL_MS=4000

# Optional: only if your API expects an admin key for "Clear all data" in the sidebar.
# VITE_ADMIN_API_KEY=
